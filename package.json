{
  "name": "flowscreen",
  "version": "0.1.6",
  "description": "Beautiful, production-ready error and state screens for React and Next.js.",
  "homepage": "https://github.com/hamzauguz/flowscreen#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamzauguz/flowscreen.git"
  },
  "bugs": {
    "url": "https://github.com/hamzauguz/flowscreen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Hamza Uguz",
    "url": "https://github.com/hamzauguz"
  },
  "keywords": [
    "react",
    "nextjs",
    "error-page",
    "error-screen",
    "state-screen",
    "empty-state",
    "maintenance-page",
    "saas",
    "ui-library",
    "typescript"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack:local": "npm run clean && npm run type-check && npm run build && npm pack",
    "release": "npm version patch && npm publish"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
